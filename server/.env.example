# ─── Server ───────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_me_to_a_random_string
JWT_EXPIRES_IN=7d

# ─── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=paperphone
DB_PASS=changeme
DB_NAME=paperphone

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASS=

# ─── Cloudflare R2 (S3-compatible object storage) ────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=paperphone
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Cloudflare TURN (for cross-network WebRTC calls) ────────
# CF_CALLS_APP_ID=
# CF_CALLS_APP_SECRET=

# ─── Metered.ca TURN (free alternative for WebRTC calls) ─────
# METERED_TURN_API_KEY=

# ─── Web Push (VAPID) ────────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@paperphone.app

# ─── Firebase Cloud Messaging (Capacitor Android push) ───────
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# ─── OneSignal (Median.co native push) ───────────────────────
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_KEY=

# ─── Telegram Sticker Packs ──────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# STICKER_PACKS=pack_name:Label,other_pack:Other Label
