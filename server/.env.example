# ─── Server ───────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_me_to_a_random_string
JWT_EXPIRES_IN=7d

# ─── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=paperphoneplus
DB_PASS=changeme
DB_NAME=paperphoneplus

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASS=

# ─── Cloudflare R2 (S3-compatible object storage) ────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=paperphoneplus
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Cloudflare TURN (for cross-network WebRTC calls) ────────
# CF_CALLS_APP_ID=
# CF_CALLS_APP_SECRET=

# ─── Metered.ca TURN (free alternative for WebRTC calls) ─────
# METERED_TURN_API_KEY=

# ─── Web Push (VAPID) ────────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@paperphoneplus.app

# ─── Firebase Cloud Messaging (Capacitor Android push) ───────
# For direct FCM: set all 3 variables below (app developer's own server)
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=
#
# ─── FCM Push Relay ──────────────────────────────────────────
# On the relay host (app developer's server): enable the relay endpoint
# FCM_RELAY_SECRET=a_long_random_secret
#
# On self-hosted servers (no Firebase credentials): point to the relay
# FCM_RELAY_URL=https://your-relay-server.com
# FCM_RELAY_KEY=a_long_random_secret

# ─── OneSignal (Median.co native push) ───────────────────────
# For direct OneSignal: set both variables below (app developer's own server)
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_KEY=
#
# ─── OneSignal Push Relay ────────────────────────────────────
# On the relay host (app developer's server): enable the relay endpoint
# ONESIGNAL_RELAY_SECRET=a_long_random_secret
#
# On self-hosted servers (no OneSignal credentials): point to the relay
# ONESIGNAL_RELAY_URL=https://your-relay-server.com
# ONESIGNAL_RELAY_KEY=a_long_random_secret

# ─── ntfy Push (Chinese Android without Google Services) ─────
# NTFY_BASE_URL=https://ntfy.sh
# NTFY_TOKEN=

# ─── Apple Push Notification Service (iOS native push) ───────
# For direct APNS: set all 5 variables below (app developer's own server)
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_PRIVATE_KEY=
# APNS_BUNDLE_ID=com.example.paperphoneplus
# APNS_SANDBOX=false
#
# ─── APNS Push Relay ─────────────────────────────────────────
# On the relay host (app developer's server): enable the relay endpoint
# APNS_RELAY_SECRET=a_long_random_secret
#
# On self-hosted servers (no Apple credentials): point to the relay
# APNS_RELAY_URL=https://your-relay-server.com
# APNS_RELAY_KEY=a_long_random_secret

# ─── Telegram Sticker Packs ──────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# STICKER_PACKS=pack_name:Label,other_pack:Other Label

# ─── Admin Panel ─────────────────────────────────────────────
ADMIN_PATH=/admin
ADMIN_PASSWORD=change_me_to_a_strong_password
